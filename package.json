{
  "name": "discord-bot",
  "version": "0.1.0",
  "description": "Production-grade modular Discord bot with TypeScript",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup",
    "start": "node dist/index.js",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "db:migrate": "prisma migrate deploy",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "db:migrate:dev": "prisma migrate dev",
    "prepare": "husky"
  },
  "keywords": [
    "discord",
    "bot",
    "typescript",
    "modular"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@sentry/node": "^8.0.0",
    "discord.js": "^14.14.1",
    "dotenv": "^16.4.5",
    "fastify": "^5.8.5",
    "glob": "^13.0.6",
    "i18next": "^23.10.1",
    "i18next-fs-backend": "^2.3.0",
    "ioredis": "^5.3.2",
    "node-cron": "^3.0.3",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "prisma": "^5.10.2",
    "reflect-metadata": "^0.2.2",
    "tsyringe": "^4.8.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/ioredis": "^5.0.0",
    "@types/node": "^20.11.0",
    "@types/node-cron": "^3.0.11",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-import": "^2.29.1",
    "husky": "^9.0.0",
    "lint-staged": "^15.2.0",
    "prettier": "^3.2.0",
    "tsup": "^8.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^4.1.5"
  },
  "packageManager": "pnpm@8.0.0",
  "engines": {
    "node": ">=20.0.0"
  }
}
