# Discord Bot Configuration
# ==========================
# Required: These values must be set for the bot to start

# Discord Bot Token from Discord Developer Portal
# Required: true
DISCORD_TOKEN=your_discord_token_here

# Discord Application (Bot) Client ID
# Required: true
DISCORD_CLIENT_ID=your_client_id_here

# Discord Development Guild ID (optional)
# Used for rapid testing of slash commands in a single guild
# Required: false (optional, but recommended for development)
DISCORD_DEV_GUILD_ID=your_development_guild_id_here

# Database Configuration
# ======================

# PostgreSQL connection URL
# Format: postgresql://username:password@host:port/database_name
# Required: true
DATABASE_URL=postgresql://user:password@localhost:5432/discord_bot

# Redis Connection URL
# Format: redis://username:password@host:port/database
# Required: true
REDIS_URL=redis://localhost:6379/0

# Monitoring & Logging
# ====================

# Sentry DSN for error tracking (optional)
# Required: false
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project

# Environment: development, production, or test
# Default: development
NODE_ENV=development

# Log level: trace, debug, info, warn, error, fatal
# Default: info
LOG_LEVEL=info

# Bot Operational Settings
# ========================

# Port for the health check HTTP server
# Default: 3000
HEALTH_PORT=3000

# Text command prefix (fallback for legacy commands)
# Default: !
BOT_PREFIX=!

# Enable maintenance mode on startup
# Default: false
MAINTENANCE_MODE=false

# Enable sharding for large bot deployments
# Default: false
SHARDING_ENABLED=false

# Bot owner Discord IDs (comma-separated list)
# These users have access to owner-only commands
# Default: empty
BOT_OWNER_IDS=123456789012345678,987654321098765432